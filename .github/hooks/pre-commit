#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
# TSFSYSTEM Pre-commit Hook — Repo Hygiene Enforcement
# Install: cp .github/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# ═══════════════════════════════════════════════════════════════
set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

# ── 1. Block large files (>10MB) ──────────────────────────────
MAX_SIZE=$((10 * 1024 * 1024))
while IFS= read -r file; do
    if [ -f "$file" ]; then
        size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo -e "${RED}BLOCKED:${NC} $file is $(($size / 1024 / 1024))MB (limit: 10MB)"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=ACM)

# ── 2. Block forbidden file types ─────────────────────────────
FORBIDDEN_PATTERNS=(
    '\.sqlite3$'
    '\.sqlite$'
    '\.sql$'
    '\.sql\.gz$'
    '\.env$'
    '\.env\.'
    'db\.sqlite3'
)
for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    matches=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$pattern" | grep -v '\.example' || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}BLOCKED:${NC} Forbidden file pattern '$pattern':"
        echo "$matches" | sed 's/^/  /'
        ERRORS=$((ERRORS + 1))
    fi
done

# ── 3. Block forbidden paths ──────────────────────────────────
FORBIDDEN_PATHS=(
    '^ARCHIVE/'
    '^restored/'
    '^_inventory_mode_src/'
    '^\.backups/'
    '^erp_backend/media/'
    '^erp_backend/staticfiles/'
    '^dist/'
    '^erp_backend/dist/'
)
for path in "${FORBIDDEN_PATHS[@]}"; do
    matches=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$path" || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}BLOCKED:${NC} Forbidden path '$path':"
        echo "$matches" | sed 's/^/  /'
        ERRORS=$((ERRORS + 1))
    fi
done

# ── 4. Root file count check ─────────────────────────────────
ROOT_COUNT=$(git diff --cached --name-only --diff-filter=ACM | grep -cv '/' 2>/dev/null || echo 0)
if [ "$ROOT_COUNT" -gt 5 ]; then
    echo -e "${YELLOW}WARNING:${NC} Adding $ROOT_COUNT files to repo root. Keep root clean (<25 files)."
fi

# ── Result ────────────────────────────────────────────────────
if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}Commit blocked: $ERRORS hygiene violation(s)${NC}"
    echo -e "${RED}To skip (emergency only): git commit --no-verify${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
fi

exit 0
