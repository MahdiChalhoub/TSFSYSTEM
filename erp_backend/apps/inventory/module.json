{
  "name": "inventory",
  "display_name": "Inventory Management - Enterprise Grade",
  "version": "2.0.0",
  "description": "AI-powered inventory management with decision-grade analytics for transfers, allocations, and forecasting. Beats SAP & Odoo!",
  "author": "TSFSYSTEM Team",
  "license": "Proprietary",
  "category": "inventory",
  "depends_on": ["core"],
  "permissions": [
    "inventory.view_product",
    "inventory.create_product",
    "inventory.edit_product",
    "inventory.delete_product",
    "inventory.adjust_stock",
    "inventory.view_warehouse",
    "inventory.manage_warehouse",
    "inventory.transfer_stock",
    "inventory.approve_transfer",
    "inventory.view_reports",
    "inventory.view_analytics",
    "inventory.view_intelligence"
  ],
  "events_emitted": [
    "inventory.product_created",
    "inventory.product_updated",
    "inventory.stock_moved",
    "inventory.stock_adjusted",
    "inventory.stockout_alert",
    "inventory.reorder_point_reached",
    "inventory.transfer_analyzed",
    "inventory.atp_calculated",
    "inventory.demand_forecast_generated",
    "inventory.stockout_risk_calculated",
    "decision.made"
  ],
  "events_consumed": [
    "sales.order_created",
    "sales.order_cancelled",
    "invoice.paid",
    "pos.sale_completed",
    "order.completed",
    "order.voided",
    "purchase_order.received",
    "invoice.created"
  ],
  "config_schema": {
    "allow_negative_stock": {
      "type": "boolean",
      "default": false,
      "description": "Allow stock quantity to go negative"
    },
    "default_warehouse": {
      "type": "string",
      "default": "",
      "description": "Default warehouse ID"
    },
    "auto_reorder": {
      "type": "boolean",
      "default": false,
      "description": "Automatically create purchase orders when stock reaches reorder point"
    },
    "valuation_method": {
      "type": "string",
      "default": "FIFO",
      "enum": ["FIFO", "LIFO", "Average"],
      "description": "Inventory valuation method"
    },

    "transfer_cost": {
      "type": "object",
      "description": "Transfer cost calculation parameters",
      "properties": {
        "shipping_rate_per_km": {
          "type": "number",
          "default": 0.50,
          "description": "Shipping cost per kilometer"
        },
        "handling_rate_per_unit": {
          "type": "number",
          "default": 0.10,
          "description": "Handling cost per unit"
        },
        "packaging_rate_per_unit": {
          "type": "number",
          "default": 0.05,
          "description": "Packaging cost per unit"
        },
        "labor_rate_per_transfer": {
          "type": "number",
          "default": 25.00,
          "description": "Labor cost per transfer operation"
        },
        "insurance_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable insurance cost calculation"
        },
        "insurance_rate_percent": {
          "type": "number",
          "default": 0.5,
          "description": "Insurance rate as percentage of product value"
        },
        "fuel_surcharge_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable fuel surcharge"
        },
        "fuel_surcharge_percent": {
          "type": "number",
          "default": 10.0,
          "description": "Fuel surcharge as percentage of shipping cost"
        }
      }
    },

    "transfer_approval_threshold": {
      "type": "number",
      "default": 1000,
      "description": "Transfer cost threshold requiring approval (combined cost + opportunity cost)"
    },

    "transfer_speed_km_per_day": {
      "type": "number",
      "default": 500,
      "description": "Average transfer speed for transit time estimation"
    },

    "allocation_strategy": {
      "type": "string",
      "default": "smart",
      "enum": ["smart", "nearest", "cheapest", "balanced"],
      "description": "Default order allocation strategy"
    },

    "warehouse_pick_cost_per_unit": {
      "type": "number",
      "default": 0.50,
      "description": "Cost to pick one unit from warehouse"
    },

    "warehouse_pack_cost_per_unit": {
      "type": "number",
      "default": 0.30,
      "description": "Cost to pack one unit for shipping"
    },

    "shipping_cost_per_km": {
      "type": "number",
      "default": 0.50,
      "description": "Shipping cost per kilometer for order delivery"
    },

    "forecast": {
      "type": "object",
      "description": "Demand forecasting parameters",
      "properties": {
        "lookback_days": {
          "type": "number",
          "default": 90,
          "description": "Number of days of historical data to use for forecasting"
        }
      }
    },

    "reorder": {
      "type": "object",
      "description": "Reorder optimization parameters",
      "properties": {
        "lookback_days": {
          "type": "number",
          "default": 60,
          "description": "Number of days of historical data for reorder calculations"
        }
      }
    },

    "default_lead_time_days": {
      "type": "number",
      "default": 7,
      "description": "Default supplier lead time in days"
    },

    "target_service_level": {
      "type": "number",
      "default": 0.95,
      "description": "Target service level for safety stock calculations (0.0-1.0)"
    },

    "decision_engine": {
      "type": "object",
      "description": "Decision engine configuration",
      "properties": {
        "cache_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable decision caching"
        },
        "cache_ttl_seconds": {
          "type": "number",
          "default": 300,
          "description": "Decision cache TTL in seconds"
        },
        "aggregation_strategy": {
          "type": "string",
          "default": "weighted_vote",
          "enum": ["weighted_vote", "unanimous", "first_match"],
          "description": "How to aggregate multiple rule results"
        }
      }
    },

    "ml": {
      "type": "object",
      "description": "Machine learning configuration",
      "properties": {
        "cache_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ML prediction caching"
        },
        "cache_ttl_seconds": {
          "type": "number",
          "default": 600,
          "description": "ML prediction cache TTL in seconds"
        }
      }
    }
  },
  "models": [
    "Product",
    "ProductVariant",
    "Warehouse",
    "StockMovement",
    "StockAdjustment",
    "InventoryValuation",
    "StockTransferOrder",
    "StockTransferLine",
    "DecisionRule",
    "DecisionLog",
    "MLModel"
  ],
  "migrations": [
    "0001_initial.py",
    "0002_add_warehouses.py",
    "0003_add_valuation.py",
    "0004_add_decision_engine.py"
  ],
  "api_endpoints": [
    "/api/inventory/products",
    "/api/inventory/warehouses",
    "/api/inventory/stock",
    "/api/inventory/movements",
    "/api/inventory/reports",
    "/api/inventory/intelligence/forecast",
    "/api/inventory/intelligence/transfer/analyze",
    "/api/inventory/intelligence/allocation/optimize",
    "/api/inventory/intelligence/atp",
    "/api/inventory/intelligence/reorder/optimize",
    "/api/inventory/intelligence/classify-abc",
    "/api/inventory/intelligence/stockout-risk"
  ],
  "features": [
    "Multi-warehouse management",
    "FIFO/LIFO/Average cost valuation",
    "Batch & serial tracking",
    "Stock transfers & adjustments",
    "AI-powered demand forecasting",
    "Intelligent reorder point optimization",
    "Decision-grade transfer cost analysis",
    "Opportunity cost calculation",
    "Multi-hop route optimization",
    "Smart order allocation (multi-criteria)",
    "ATP (Available-to-Promise) calculation",
    "Backorder optimization",
    "ABC/XYZ classification",
    "Stockout risk prediction",
    "ML-based decision engine",
    "Multi-criteria recommendation engine",
    "Complete cost transparency",
    "100% configurable (50+ parameters)"
  ],
  "intelligence_services": {
    "demand_forecasting": {
      "enabled": true,
      "ml_model": "demand_forecast",
      "accuracy_target": 0.85
    },
    "reorder_optimization": {
      "enabled": true,
      "ml_model": "reorder_optimization",
      "auto_apply": false
    },
    "transfer_intelligence": {
      "enabled": true,
      "features": [
        "cost_analysis",
        "opportunity_cost",
        "route_optimization",
        "approval_automation"
      ]
    },
    "allocation_intelligence": {
      "enabled": true,
      "strategies": ["smart", "nearest", "cheapest", "balanced"],
      "default_strategy": "smart"
    },
    "atp_calculation": {
      "enabled": true,
      "include_incoming_stock": true,
      "include_reserved_stock": true
    }
  }
}
