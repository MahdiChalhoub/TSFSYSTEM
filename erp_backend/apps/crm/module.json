{
  "name": "crm",
  "display_name": "Customer Relationship Management",
  "version": "1.1.0",
  "description": "Customer management, contacts, leads, opportunities, and customer interactions",
  "author": "TSFSYSTEM Team",
  "license": "Proprietary",
  "category": "crm",
  "depends_on": ["core"],
  "permissions": [
    "crm.view_customer",
    "crm.create_customer",
    "crm.edit_customer",
    "crm.delete_customer",
    "crm.view_contact",
    "crm.create_contact",
    "crm.view_lead",
    "crm.manage_lead",
    "crm.export_data"
  ],
  "events_emitted": [
    "crm.customer_created",
    "crm.customer_updated",
    "crm.contact_created",
    "crm.lead_created",
    "crm.lead_converted"
  ],
  "events_consumed": [
    "invoice.created",
    "payment.received",
    "sales.order_created"
  ],
  "config_schema": {
    "lead_stages": {
      "type": "array",
      "default": ["New", "Contacted", "Qualified", "Proposal", "Won", "Lost"],
      "description": "Lead pipeline stages"
    },
    "auto_create_customer_from_lead": {
      "type": "boolean",
      "default": true,
      "description": "Automatically create customer when lead is won"
    }
  },
  "models": [
    "Customer",
    "Contact",
    "Lead",
    "Opportunity",
    "CustomerInteraction"
  ],
  "migrations": [
    "0001_initial.py",
    "0002_add_leads.py"
  ],
  "api_endpoints": [
    "/api/crm/customers",
    "/api/crm/contacts",
    "/api/crm/leads",
    "/api/crm/opportunities"
  ]
}
