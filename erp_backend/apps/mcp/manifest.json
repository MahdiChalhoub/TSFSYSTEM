{
    "code": "mcp",
    "name": "MCP AI Connector",
    "description": "Model Context Protocol integration for AI assistants. Exposes platform APIs as tools for external AI models.",
    "version": "1.1.0",
    "category": "integration",
    "is_core": false,
    "author": "Dajingo Platform",
    "minimum_kernel_version": "8.3.0",
    "dependencies": [
        "core"
    ],
    "permissions": [
        {
            "code": "mcp.view",
            "label": "View MCP Settings"
        },
        {
            "code": "mcp.manage",
            "label": "Manage MCP Configuration"
        },
        {
            "code": "mcp.chat",
            "label": "Use AI Chat"
        },
        {
            "code": "mcp.tools",
            "label": "Execute AI Tools"
        },
        {
            "code": "mcp.admin",
            "label": "Full MCP Administration"
        }
    ],
    "models": [
        "MCPProvider",
        "MCPConnection",
        "MCPTool",
        "MCPConversation",
        "MCPMessage",
        "MCPUsageLog"
    ],
    "routes": [
        {
            "path": "/saas/mcp",
            "label": "MCP Dashboard"
        },
        {
            "path": "/saas/mcp/providers",
            "label": "AI Providers"
        },
        {
            "path": "/saas/mcp/tools",
            "label": "Tools"
        },
        {
            "path": "/saas/mcp/conversations",
            "label": "Conversations"
        },
        {
            "path": "/saas/mcp/settings",
            "label": "Settings"
        }
    ],
    "sidebar_items": [
        {
            "title": "AI Integration",
            "icon": "Bot",
            "visibility": "saas",
            "children": [
                {
                    "title": "Dashboard",
                    "path": "/saas/mcp",
                    "icon": "LayoutDashboard"
                },
                {
                    "title": "Providers",
                    "path": "/saas/mcp/providers",
                    "icon": "Cloud"
                },
                {
                    "title": "Tools",
                    "path": "/saas/mcp/tools",
                    "icon": "Wrench"
                },
                {
                    "title": "AI Chat",
                    "path": "/saas/mcp/chat",
                    "icon": "Sparkles"
                },
                {
                    "title": "Conversations",
                    "path": "/saas/mcp/conversations",
                    "icon": "MessageSquare"
                },
                {
                    "title": "Settings",
                    "path": "/saas/mcp/settings",
                    "icon": "Settings"
                }
            ]
        }
    ],
    "settings_schema": {
        "default_provider": {
            "type": "string",
            "default": "",
            "label": "Default AI Provider"
        },
        "max_tokens_per_request": {
            "type": "integer",
            "default": 4096,
            "label": "Max Tokens Per Request"
        },
        "rate_limit_per_minute": {
            "type": "integer",
            "default": 60,
            "label": "Requests Per Minute Limit"
        },
        "enable_tool_execution": {
            "type": "boolean",
            "default": true,
            "label": "Allow Tool Execution"
        }
    },
    "created_at": "2026-02-04",
    "updated_at": "2026-02-04"
}