{
  "name": "tsfci",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:module": "bash scripts/dev-module.sh",
    "deploy:module": "bash scripts/deploy-module.sh",
    "package:kernel": "bash scripts/package-kernel.sh",
    "package:frontend": "bash scripts/package-frontend.sh",
    "package:module": "bash scripts/package-module.sh",
    "build": "node scripts/check-kernel-integrity.js && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "kernel-check": "node scripts/check-kernel-integrity.js",
    "typecheck": "npx tsc --noEmit 2>&1 | grep '^src/' || echo '✅ No TypeScript errors in src/'",
    "typecheck:pos": "npx tsc --noEmit 2>&1 | grep -E '(POSLayout|usePOSTerminal|TerminalContext|POSToolbar)' || echo '✅ POS clean'",
    "typecheck:finance": "npx tsc --noEmit 2>&1 | grep -E 'finance' || echo '✅ Finance clean'",
    "verify": "npm run typecheck && npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:backend": "node scripts/run-tests.js",
    "test:smoke": "node scripts/smoke-tests.js",
    "test:all": "vitest run && node scripts/run-tests.js && node scripts/smoke-tests.js",
    "security:scan": "node scripts/security-scan.js",
    "health": "bash scripts/health-monitor.sh",
    "health:watch": "bash scripts/health-monitor.sh --watch",
    "agent:verify": "bash scripts/agent-verify.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.35.2",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "papaparse": "^5.5.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^14.4.0",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}