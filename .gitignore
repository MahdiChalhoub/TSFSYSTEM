# ═══════════════════════════════════════════════════════════════
# TSFSYSTEM .gitignore — Enterprise-grade exclusion rules
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
venv/
*/venv/
.venv/
*/.venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/

# ── Next.js / Frontend builds ─────────────────────────────────
/.next/
/out/
/build/
/dist/
*/dist/
/coverage/
*.tsbuildinfo
next-env.d.ts
prerender-manifest.json
.deploy-package-lock.md5

# ── Env & Secrets ─────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
SSH_PUBLIC_KEY.txt

# ── Database ──────────────────────────────────────────────────
*.sqlite3
*.sqlite
*.sqlite-journal
*.db
*.sql
*.sql.gz
/pg_data/
/pgdata/
pg_data_bak_*/

# ── Media & static (runtime-generated) ────────────────────────
media/
erp_backend/media/
erp_backend/staticfiles/
erp_backend/logos/
/static/root/

# ── Logs & runtime output ────────────────────────────────────
*.log
*.log.*
*.pid
*.out
*.err
*.stackdump
logs/
erp_backend/celerybeat-schedule
erp_backend/gunicorn.ctl

# ── Temporary / build artifacts ───────────────────────────────
tmp/
temp/
*.bak
*.backup
*.tar.gz
*.tsx.new
*.tsx.backup
*.swp
*~

# ── Legacy / recovery directories (NEVER track) ──────────────
ARCHIVE/
restored/
_inventory_mode_src/
.backups/
releases/
_quarantine/
erp_backend/_quarantine/

# ── Agent / AI session artifacts ──────────────────────────────
.ai/
.agent/
.gemini/
.claude/
.cursor/

# ── OS / editor ──────────────────────────────────────────────
.DS_Store
.vscode/
.vercel

