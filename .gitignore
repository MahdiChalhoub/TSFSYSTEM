# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/pg_data/
/pgdata/
*.sqlite
*.sqlite-journal

# django migrations (optional, usually kept, but for this project we might want to ignore local ones if they conflict)
# actually, keep migrations but ignore __pycache__
__pycache__/
*.py[cod]
*$py.class

# Python virtual environment (CRITICAL: protects server venv from git clean)
venv/
*/venv/
.venv/

# local development
.agent/
.gemini/
# Engine Guard Scripts are essential
!scripts/

# Heavy data and backups
pg_data_bak_*/
*_backup*/
*.bak
*.log
tmp/
temp/
/media/
media/
erp_backend/media/
/static/root/

# Temp scripts
erp_backend/rename_tables.py
erp_backend/rename_kernel_tables.py
erp_backend/rename_remaining_tables.py
erp_backend/test_coa_visibility.py
erp_backend/test_registration.py
erp_backend/check_tables.py
erp_backend/clear_migrations.py
erp_backend/list_applied_migrations.py
erp_backend/list_all_migrations.py

# Debug output files (root junk)
*_output.txt
*_logs.txt
*_logs_long.txt
*_schema.txt
*_cols.txt
*_err*.txt
*_check*.txt
*.diff
django_*.txt
server_*.txt
frontend_*.log
deploy.log
