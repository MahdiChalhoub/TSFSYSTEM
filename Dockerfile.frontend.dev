# ═══════════════════════════════════════════════════════════════════════════════
# TSFSYSTEM — Frontend Dev Dockerfile
# Hot-reload Next.js Turbopack development server
# ═══════════════════════════════════════════════════════════════════════════════

FROM node:22-alpine

# Required for some native modules
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Install dependencies first (cached layer — only re-runs if package.json changes)
COPY package.json package-lock.json* ./
COPY patches ./patches
RUN npm install

# Copy project files (for initial build — source is volume-mounted at runtime)
COPY . .

# Remove .next cache to ensure clean start
RUN rm -rf .next

EXPOSE 3000

# Enable filesystem polling for Docker volume mounts
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true
ENV NEXT_TELEMETRY_DISABLED=1

# Start Turbopack dev server with hot reload
CMD ["npm", "run", "dev", "--", "-p", "3000", "-H", "0.0.0.0"]
